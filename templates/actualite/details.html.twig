{% extends "base.html.twig" %}

{% block title %}
	{{article.title}}
{% endblock %}

{% block body %}
	<article>
		<img style="background-image: url(' ../../uploads/articles/{{article.image}}'); background-repeat: no-repeat; background-position: center; background-size:cover; height:300px; width:100%"></img>
	<section class="p-4">
		<h2 class="h1" style="opacity:1">{{article.title}}</h2>
		<section class="">
			<p class="m-0">
				Edité le :
				{{article.updatedAt|date("d/m/Y")}}
			</p>
			<p class="m-0">
				categorie :
				{{article.categorie}}
			</p>
		</section>
		<section class="mt-3">
			<h6 class="" style="">
				{{article.intro}}
			</h6>
		</section>
		<section class="mt-3">
			<p class="" style="">
				{{article.contenu}}
			</p>
		</section>
	</section>
</article>{% endblock %}
