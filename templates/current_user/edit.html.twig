{% extends "base.html.twig" %}

{% block body %}
	<section class="p-5">
		{% for flash_error in app.flashes('verify_email_error') %}
			<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
		{% endfor %}

		<h1>Modifier ses données</h1>

		{{ form_start(formulaire) }}
		{{ form_row(formulaire.name, {
            label: 'Nom'
        }) }}
		{{ form_row(formulaire.firstname, {
            label: 'Prenom'
        }) }}
		{{ form_row(formulaire.email) }}
		{{ form_row(formulaire.plainPassword, {
            label: 'Mot de passe'
        }) }}
		{{ form_row(formulaire.photo) }}
		{{ form_row(formulaire.agreeTerms, {
			label:'Accepter les termes'
		}) }}
		<button type="submit" class="btn btn-primary btn-lg mt-3">Register</button>
		{{ form_end(formulaire) }}
	</section>
{% endblock %}
